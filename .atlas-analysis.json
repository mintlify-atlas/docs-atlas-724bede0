  "keyFeatures": [
    "Low-level cross-platform C tensor library with no third-party dependencies",
    "Integer quantization support (Q4, Q5, Q8, and more) for efficient inference",
    "Automatic differentiation via computation graph",
    "ADAM and L-BFGS optimizers for model training",
    "Zero memory allocations at runtime",
    "Broad hardware backend support: CPU, CUDA, Metal, Vulkan, OpenCL, SYCL, WebGPU, RPC",
    "GGUF binary file format for fast model loading and saving",
    "Multi-threading support with configurable thread pools",
    "SIMD optimizations (AVX, AVX2, AVX-512, ARM NEON)"
  ],
  "publicApiSurface": [
    "ggml_init / ggml_free / ggml_reset",
    "ggml_new_tensor_1d / ggml_new_tensor_2d / ggml_new_tensor_3d / ggml_new_tensor_4d",
